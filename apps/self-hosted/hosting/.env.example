# Ecency Managed Hosting Platform - Environment Variables

# =============================================================================
# Domain Configuration
# =============================================================================
BASE_DOMAIN=blogs.ecency.com

# =============================================================================
# SSL / Let's Encrypt
# =============================================================================
ACME_EMAIL=admin@ecency.com

# Cloudflare API (for wildcard SSL)
CF_API_EMAIL=your-cloudflare-email@example.com
CF_API_KEY=your-cloudflare-api-key

# =============================================================================
# Database
# =============================================================================
POSTGRES_PASSWORD=your-secure-password-here

# =============================================================================
# Security
# =============================================================================
JWT_SECRET=your-jwt-secret-here

# Traefik dashboard auth (generate with: htpasswd -nb admin password)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xyz...

# =============================================================================
# Hive Blockchain
# =============================================================================
HIVE_API_URL=https://api.hive.blog

# Account to receive HBD payments
PAYMENT_ACCOUNT=ecency.hosting

# Monthly subscription price in HBD (must match the Stripe USD price below)
MONTHLY_PRICE_HBD=2.000

# Pro plan upgrade price in HBD (custom domain — Phase 2)
PRO_UPGRADE_PRICE_HBD=5.000

# =============================================================================
# x402 (Ecency's Hive micropayment rail) — showcases the protocol at checkout.
# Point at the live facilitator; leave empty to hide the x402 option.
# =============================================================================
X402_FACILITATOR_URL=https://x402.ecency.com

# =============================================================================
# Card payments are handled by the central ePoints Stripe rail — NOT here. There
# are no Stripe keys in the hosting service. ePoints calls the internal activation
# endpoint (POST /v1/internal/activate) after a paid order, authenticated by this
# shared secret (same pattern as ePoints' STRIPE_INTERNAL_SECRET). Empty = card
# activation disabled (the endpoint fails closed).
# =============================================================================
HOSTING_INTERNAL_SECRET=
# Show/hide the card option in the signup UI + the price it displays (200 = $2.00).
HOSTING_CARD_ENABLED=true
HOSTING_CARD_USD_CENTS=200
