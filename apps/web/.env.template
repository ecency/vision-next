# Public (exposed to browser)
NEXT_PUBLIC_APP_BASE=https://ecency.com
NEXT_PUBLIC_APP_NAME=Ecency
NEXT_PUBLIC_APP_TITLE="Ecency - smart, decentralized, rewarding social network without limits"
NEXT_PUBLIC_APP_DESCRIPTION="Discover and build a community, niche and be rewarded for blogs, votes, contributions and reward esteemed friends and followers."
NEXT_PUBLIC_TWITTER_HANDLE=@ecency_official
NEXT_PUBLIC_APP_LOGO=/assets/logo-circle.svg
NEXT_PUBLIC_IMAGE_SERVER=https://i.ecency.com
NEXT_PUBLIC_NWS_SERVER=wss://enotify.ecency.com
# Geo-tag picker (all optional). Search uses an offline cities dataset + an
# open-source geocoder; the map uses OpenStreetMap tiles. The public defaults
# below are fine for normal use — requests are made client-side (distributed
# across users' browsers), debounced, and most lookups hit the offline dataset.
# Only override these to point at a self-hosted geocoder / tile provider if
# volume ever grows enough to warrant it. NOTE: if you change these hosts, also
# add their origins to the CSP connect-src / img-src in next.config.js (the
# defaults are derived automatically from these vars).
NEXT_PUBLIC_GEOCODER_HOST=https://photon.komoot.io
NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# Stripe publishable key (public). When empty, card payment for Points is hidden.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_THREESPEAK_EMBED_ENDPOINT=https://embed.3speak.tv

# Server-only (never exposed to browser)
USE_PRIVATE=1
# Internal API host for SSR calls (bypasses Cloudflare). Set to Docker service URL in production.
# INTERNAL_API_HOST=http://vapi:4000
HIVESIGNER_CLIENT_ID=ecency.app
HIVESIGNER_SECRET=
VITE_HELIUS_API_KEY=
PLAUSIBLE_API_KEY=
SENTRY_AUTH_TOKEN=

# 3Speak Embed API
THREESPEAK_EMBED_API_KEY=

# Mattermost integration
MATTERMOST_BASE_URL=https://mattermost.example.com/api/v4
MATTERMOST_ADMIN_TOKEN=
MATTERMOST_TEAM_ID=
# Optional: Additional allowed origins for WebSocket CORS (comma-separated)
MATTERMOST_WS_ALLOWED_ORIGINS=
