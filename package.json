{
  "name": "vision-next",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @ecency/web dev",
    "build": "pnpm --filter @ecency/web build",
    "start": "pnpm --filter @ecency/web start",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @ecency/web test",
    "typecheck": "pnpm -r --if-present typecheck",
    "validate:dmca": "node packages/sdk/scripts/validate-dmca-patterns.cjs apps/web/public/dmca/dmca-tags.json apps/web/public/dmca/dmca-posts.json",
    "build:packages": "pnpm -F @ecency/sdk -F @ecency/wallets -F @ecency/render-helper -F @ecency/ui build",
    "ui": "pnpm --filter @ecency/ui build",
    "dev:ui": "pnpm --filter @ecency/ui dev",
    "sdk": "pnpm --filter @ecency/sdk build",
    "wallets": "pnpm --filter @ecency/wallets build",
    "render-helper": "pnpm --filter @ecency/render-helper build",
    "dev:self": "pnpm --filter @ecency/self-hosted dev",
    "dev:sdk": "pnpm --filter @ecency/sdk dev",
    "dev:wallets": "pnpm --filter @ecency/wallets dev",
    "publish:sdk": "cd packages/sdk && npx -y npm@11 publish --access public",
    "publish:wallets": "cd packages/wallets && npx -y npm@11 publish --access public",
    "publish:render-helper": "cd packages/render-helper && npx -y npm@11 publish --access public",
    "publish:ui": "cd packages/ui && npx -y npm@11 publish --access public",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.8",
    "@types/node": "^22",
    "eslint": "^8",
    "sass-embedded": "^1.93.2",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "postcss": "^8.4.49",
    "postcss-scss": "^4.0.9"
  }
}
